# Which bfoster-services instance to use: local | production
VITE_API_TARGET=local

# Optional URL overrides (defaults shown)
# VITE_API_LOCAL_URL=http://localhost:8081
# VITE_API_PRODUCTION_URL=https://bfoster-services.herokuapp.com

# Legacy: set full base URL directly (overrides VITE_API_TARGET)
# VITE_API_BASE_URL=http://localhost:8081

# Admin panel password (Admin route)
# VITE_ADMIN_PASSWORD=your_password_here
